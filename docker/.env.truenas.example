# ============================================================================
# SSO服务 TrueNAS环境配置模板
# 使用方法: 复制此文件为 .env 并修改配置
# ============================================================================

# ----------------------------------------------------------------------------
# 镜像配置
# ----------------------------------------------------------------------------
DOCKERHUB_USER=your-dockerhub-user    # Docker Hub用户名
IMAGE_TAG=latest                       # 镜像标签

# ----------------------------------------------------------------------------
# 部署配置
# ----------------------------------------------------------------------------
SSO_HOST_PORT=9090                     # 主机映射端口
KEYS_PATH=./keys                       # RSA密钥本地路径（相对于compose文件）

# ----------------------------------------------------------------------------
# 服务器配置
# ----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=9090
SERVER_ENV=production                  # 生产环境
LAN_DEPLOYMENT=true                    # LAN部署模式，放宽部分生产环境校验

# ----------------------------------------------------------------------------
# 数据库配置 (指向TrueNAS上已部署的PostgreSQL)
# ----------------------------------------------------------------------------
DB_HOST=your-postgres-host             # TrueNAS PostgreSQL地址
DB_PORT=5432
DB_NAME=sso
DB_USER=sso
DB_PASSWORD=YourStrongPassword123!     # 必须使用强密码
DB_SSL_MODE=disable                    # 内网部署使用 disable，跨网络建议 require
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=50
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=1m
DB_QUERY_TIMEOUT=10s

# ----------------------------------------------------------------------------
# Redis配置 (指向TrueNAS上已部署的Redis)
# ----------------------------------------------------------------------------
REDIS_ENABLE=true
REDIS_HOST=your-redis-host             # TrueNAS Redis地址
REDIS_PORT=6379
REDIS_PASSWORD=                        # 如有密码请填写
REDIS_DB=0
REDIS_CONN_TIMEOUT=5s
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5

# ----------------------------------------------------------------------------
# JWT配置
# ----------------------------------------------------------------------------
JWT_PRIVATE_KEY_PATH=/keys/private.pem
JWT_PUBLIC_KEY_PATH=/keys/public.pem
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h
JWT_ISSUER=sso

KEY_ROTATION_ENABLED=false
KEY_ROTATION_INTERVAL=2160h
KEY_TRANSITION_PERIOD=24h

# ----------------------------------------------------------------------------
# 安全配置
# ----------------------------------------------------------------------------
BCRYPT_COST=12                         # 生产环境必须>=12
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=30m
MFA_RECOVERY_HMAC_KEY=your_strong_hmac_key_here  # 生产环境必须设置

# ----------------------------------------------------------------------------
# 邮件配置
# ----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# ----------------------------------------------------------------------------
# CORS配置 (必须修改为您的域名)
# ----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ----------------------------------------------------------------------------
# Metrics配置
# ----------------------------------------------------------------------------
METRICS_USERNAME=metrics
METRICS_PASSWORD=your_metrics_password

# ----------------------------------------------------------------------------
# 优雅关闭配置
# ----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT=30s
