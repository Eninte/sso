# 统一换行符：仓库内一律 LF，避免 Windows (autocrlf) 下出现幻影改动
* text=auto eol=lf

# 脚本必须保持 LF（Docker entrypoint 等在 Linux 容器内执行）
*.sh  text eol=lf
*.bash text eol=lf
Makefile text eol=lf

# 二进制文件不做换行转换
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.tar  binary
*.woff  binary
*.woff2 binary
