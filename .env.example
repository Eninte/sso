# ============================================================================
# SSO服务环境配置模板
# 使用方法: 复制此文件为 .env 并修改相应配置
#
# ⚠️ 生产环境必须修改以下配置项：
# - DB_PASSWORD: 必须使用强密码
# - DB_SSL_MODE: 必须设置为 require
# - METRICS_PASSWORD: 必须设置强密码
# - SMTP_PASSWORD: 必须设置SMTP服务密码
# - CORS_ALLOWED_ORIGINS: 必须设置允许的跨域源
# ============================================================================

# ----------------------------------------------------------------------------
# 服务器配置
# ----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0         # 服务器监听地址
SERVER_PORT=9090            # 服务器监听端口
SERVER_ENV=development      # 运行环境: development / production

# ----------------------------------------------------------------------------
# 数据库配置 (PostgreSQL)
# ----------------------------------------------------------------------------
DB_HOST=192.168.1.3         # 数据库主机 (测试环境)
DB_PORT=5432                # 数据库端口
DB_NAME=sso_test            # 数据库名称
DB_USER=sso                 # 数据库用户
DB_PASSWORD=changeme        # 数据库密码 ⚠️ 生产环境必须修改为强密码
DB_SSL_MODE=require         # SSL模式: disable / prefer / require / verify-full (生产环境必须为require或更高)

# ----------------------------------------------------------------------------
# 数据库连接池配置
# ----------------------------------------------------------------------------
DB_MAX_OPEN_CONNS=50        # 最大打开连接数
DB_MAX_IDLE_CONNS=25        # 最大空闲连接数
DB_CONN_MAX_LIFETIME=5m     # 连接最大生命周期
DB_QUERY_TIMEOUT=10s        # 查询超时时间

# ----------------------------------------------------------------------------
# Redis配置 (缓存和会话存储)
# ----------------------------------------------------------------------------
REDIS_HOST=192.168.1.3      # Redis主机 (测试环境)
REDIS_PORT=30059            # Redis端口
REDIS_PASSWORD=             # Redis密码 (测试环境无密码)

# ----------------------------------------------------------------------------
# JWT配置
# ----------------------------------------------------------------------------
JWT_PRIVATE_KEY_PATH=./keys/private.pem  # JWT私钥路径
JWT_PUBLIC_KEY_PATH=./keys/public.pem    # JWT公钥路径
JWT_ACCESS_TOKEN_TTL=15m   # Access Token有效期 (建议15分钟)
JWT_REFRESH_TOKEN_TTL=168h # Refresh Token有效期 (建议7天)
JWT_ISSUER=sso              # Token签发者标识

KEY_ROTATION_ENABLED=false  # 是否启用密钥轮换
KEY_ROTATION_INTERVAL=2160h # 密钥轮换周期 (建议90天)
KEY_TRANSITION_PERIOD=24h   # 密钥过渡期时长 (建议24小时)

# ----------------------------------------------------------------------------
# 安全配置
# ----------------------------------------------------------------------------
BCRYPT_COST=12              # bcrypt成本因子 (生产环境≥12)
RATE_LIMIT_REQUESTS=100     # 限流: 每个时间窗口的请求数
RATE_LIMIT_WINDOW=1m        # 限流时间窗口
MAX_LOGIN_ATTEMPTS=5        # 最大登录失败次数
LOCKOUT_DURATION=30m        # 账户锁定时长

# ----------------------------------------------------------------------------
# 邮件配置 (Phase 3启用)
# ----------------------------------------------------------------------------
SMTP_HOST=                  # SMTP服务器地址
SMTP_PORT=587               # SMTP端口
SMTP_USER=                  # SMTP用户名
SMTP_PASSWORD=              # SMTP密码
SMTP_FROM=noreply@example.com  # 发件人地址

# ----------------------------------------------------------------------------
# CORS配置
# ----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080  # 允许的源

# ----------------------------------------------------------------------------
# Metrics配置 (Prometheus指标端点认证)
# ----------------------------------------------------------------------------
METRICS_USERNAME=metrics     # Metrics Basic Auth用户名 (留空则禁用认证，仅开发环境建议)
METRICS_PASSWORD=<CHANGE_ME> # Metrics Basic Auth密码 ⚠️ 生产环境必须设置强密码

# ----------------------------------------------------------------------------
# SMTP配置 (邮件服务)
# ----------------------------------------------------------------------------
SMTP_HOST=smtp.qiye.aliyun.com
SMTP_PORT=465
SMTP_USER=system@eninte.com
SMTP_PASSWORD=<CHANGE_ME_SMTP_PASSWORD>
SMTP_FROM=system@eninte.com

# ----------------------------------------------------------------------------
# 测试配置 (仅用于E2E测试)
# ----------------------------------------------------------------------------
E2E_ADMIN_EMAIL=system@eninte.com    # 测试管理员邮箱
E2E_ADMIN_PASSWORD=Admin123!         # 测试管理员密码
