# ============================================================================
# SSO服务环境配置模板
# 使用方法: 复制此文件为 .env 或 .env.test 并修改相应配置
#
# 🔴 标记的配置项为必填项，缺少会导致系统无法正常运行
#
# ⚠️ 生产环境必须修改以下配置项：
# - DB_PASSWORD: 必须使用强密码
# - DB_SSL_MODE: 必须设置为 require
# - BCRYPT_COST: 必须 >= 12
# - REDIS_PASSWORD: 必须设置（docker-compose 不再提供弱密码默认值）
# - CORS_ALLOWED_ORIGINS: 必须设置允许的跨域源
# ============================================================================

# ----------------------------------------------------------------------------
# 服务器配置
# ----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0         # 服务器监听地址
SERVER_PORT=9090            # 服务器监听端口
SERVER_ENV=development      # 运行环境: development / production / test

# ----------------------------------------------------------------------------
# 数据库配置 (PostgreSQL)
# ----------------------------------------------------------------------------
DB_HOST=localhost           # 🔴 数据库主机 (必填)
DB_PORT=5432                # 🔴 数据库端口 (必填)
DB_NAME=sso                 # 🔴 数据库名称 (必填)
DB_USER=sso                 # 🔴 数据库用户 (必填)
DB_PASSWORD=changeme        # 🔴 数据库密码 (必填，生产环境必须使用强密码)
DB_SSL_MODE=require         # SSL模式: disable / prefer / require / verify-full (生产环境必须为require或更高)

# ----------------------------------------------------------------------------
# 数据库连接池配置
# ----------------------------------------------------------------------------
DB_MAX_OPEN_CONNS=100       # 最大打开连接数
DB_MAX_IDLE_CONNS=50        # 最大空闲连接数
DB_CONN_MAX_LIFETIME=5m     # 连接最大生命周期
DB_CONN_MAX_IDLE_TIME=1m    # 连接最大空闲时间（减少无效连接占用）
DB_QUERY_TIMEOUT=10s        # 查询超时时间

# ----------------------------------------------------------------------------
# Redis配置 (缓存和会话存储)
# ----------------------------------------------------------------------------
REDIS_ENABLE=true           # 是否启用Redis缓存
REDIS_HOST=localhost        # 🔴 Redis主机 (必填)
REDIS_PORT=6379             # 🔴 Redis端口 (必填)
REDIS_PASSWORD=             # Redis密码 (必填：docker-compose 启动时强制校验非空)
REDIS_DB=0                  # Redis数据库编号 (0-15)
REDIS_CONN_TIMEOUT=5s       # Redis连接超时
REDIS_POOL_SIZE=10          # Redis连接池大小
REDIS_MIN_IDLE_CONNS=5      # Redis最小空闲连接数

# ----------------------------------------------------------------------------
# JWT配置
# ----------------------------------------------------------------------------
JWT_PRIVATE_KEY_PATH=./keys/private.pem  # 🔴 JWT私钥路径 (必填)
JWT_PUBLIC_KEY_PATH=./keys/public.pem    # 🔴 JWT公钥路径 (必填)
JWT_ACCESS_TOKEN_TTL=15m   # Access Token有效期 (建议15分钟)
JWT_REFRESH_TOKEN_TTL=168h # Refresh Token有效期 (建议7天)
JWT_ISSUER=sso              # Token签发者标识

KEY_ROTATION_ENABLED=false  # 是否启用密钥轮换
KEY_ROTATION_INTERVAL=2160h # 密钥轮换周期 (建议90天)
KEY_TRANSITION_PERIOD=24h   # 密钥过渡期时长 (建议24小时)
JWT_TRANSITION_PUBKEY_PATHS= # 密钥轮换期间的旧公钥路径 (逗号分隔，如 ./keys/public-v1.pem,./keys/public-v2.pem)
JWT_KEY_ENCRYPTION_KEY=      # DB私钥信封加密KEK (64位hex=32字节AES-256；生成方式: openssl rand -hex 32)
                             # 生产环境启用 KEY_ROTATION_ENABLED 时必填，否则拒绝启动
                             # 配置后 key_versions.private_key 以 v1:gcm: 密文存储；存量明文行读取后自动懒加密回写

# ----------------------------------------------------------------------------
# 安全配置
# ----------------------------------------------------------------------------
BCRYPT_COST=12              # bcrypt成本因子 (测试环境可用10, 生产环境建议>=12)
RATE_LIMIT_REQUESTS=100     # 限流: 每个时间窗口的请求数
RATE_LIMIT_WINDOW=1m        # 限流时间窗口
MAX_LOGIN_ATTEMPTS=5        # 最大登录失败次数 (5次失败后锁定账户)
LOCKOUT_DURATION=30m        # 账户锁定时长 (30分钟)
TRUSTED_PROXIES=            # 受信代理IP (逗号分隔，支持CIDR，如 "10.0.0.1,172.16.0.0/12")
                            # 留空则不信任任何代理的 X-Real-IP 头（限流使用 RemoteAddr）

# ----------------------------------------------------------------------------
# MFA配置
# ----------------------------------------------------------------------------
MFA_RECOVERY_HMAC_KEY=      # MFA恢复码HMAC密钥 (⚠️ 生产环境必须设置强密钥，否则恢复码可被伪造)
                             # 生产环境要求至少32字节，不足将拒绝启动；生成方式: openssl rand -hex 32
MFA_CHALLENGE_TTL=5m        # MFA两阶段登录 Challenge 有效期 (默认5分钟)
                             # 密码验证通过后生成的 mfa_challenge 令牌的过期时间
                             # 过短会导致用户输入 TOTP 时被超时；过长会增加 Challenge 被盗用的窗口

# ----------------------------------------------------------------------------
# 验证码配置 (防机器人)
# ----------------------------------------------------------------------------
CAPTCHA_ENABLED=true            # 是否启用验证码 (true/false)
CAPTCHA_TTL=5m                  # 验证码有效期 (默认5分钟)
CAPTCHA_FAIL_THRESHOLD=3        # 连续失败N次后触发验证码 (默认3次)
CAPTCHA_FAIL_WINDOW=15m         # 失败计数窗口 (默认15分钟)

# ----------------------------------------------------------------------------
# 邮件配置 (SMTP服务)
# ----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com  # SMTP服务器地址 (可选，不配置则无法发送邮件)
SMTP_PORT=465               # SMTP端口 (465=SSL, 587=TLS)
SMTP_USER=                  # SMTP用户名
SMTP_PASSWORD=              # SMTP密码
SMTP_FROM=noreply@example.com  # 发件人地址

# ----------------------------------------------------------------------------
# 社交登录配置 (OAuth 2.0)
# ----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=           # Google OAuth 客户端ID (可选，不配置则禁用Google登录)
GOOGLE_CLIENT_SECRET=       # Google OAuth 客户端密钥
GITHUB_CLIENT_ID=           # GitHub OAuth 客户端ID (可选，不配置则禁用GitHub登录)
GITHUB_CLIENT_SECRET=       # GitHub OAuth 客户端密钥
# 社交登录 state 会话绑定（login CSRF 防护，T11）
# true（默认）：state 始终由服务端生成，发起端下发 HttpOnly+SameSite=Lax 指纹 Cookie，
#              回调端校验指纹匹配，无 Cookie 或指纹不匹配拒绝
# false：恢复旧行为（兼容无 Cookie 的纯 API 客户端）；生产环境关闭会输出 Warn 风险提示
SOCIAL_STATE_COOKIE_BINDING=true

# ----------------------------------------------------------------------------
# CORS配置
# ----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080  # 允许的源 (生产环境必须配置)

# ----------------------------------------------------------------------------
# Metrics配置 (Prometheus指标端点认证)
# ----------------------------------------------------------------------------
METRICS_USERNAME=metrics     # Metrics Basic Auth用户名 (留空则禁用认证，仅开发环境建议)
METRICS_PASSWORD=changeme    # Metrics Basic Auth密码 (可选，生产环境建议设置强密码)

# ----------------------------------------------------------------------------
# 优雅关闭配置
# ----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT=30s         # 优雅关闭超时时间

# ----------------------------------------------------------------------------
# 部署模式配置
# ----------------------------------------------------------------------------
LAN_DEPLOYMENT=false         # LAN部署模式 (true时放宽部分生产环境校验：允许DB_SSL_MODE=disable、MFA_RECOVERY_HMAC_KEY为空等)
                             # 仅用于内网部署，公网部署必须保持false

# ----------------------------------------------------------------------------
# 初始化面板配置（首次部署使用）
# ----------------------------------------------------------------------------
# 安全设计：初始化路由 (/init, /api/v1/init/*) 仅注册在独立 loopback HTTP 服务器上，
# 监听 127.0.0.1:9091，与公网主路由完全隔离，杜绝反向代理绕过 isLocalRequest 的风险
# 详见 internal/app/init_server.go
INIT_ENABLED=true            # 是否启用初始化面板（初始化完成后应设为 false 永久关闭）
INIT_LISTEN=127.0.0.1:9091   # 初始化面板监听地址 (强制 loopback，非 127.0.0.1/::1/localhost 会被拒绝并回退)
